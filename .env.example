# ============================================================
# Research-Radar-AI — Environment Configuration Template
# Copy this file to .env and fill in your values
# ============================================================

# Database (SQLite local file — no setup required)
# Use file:sqlite.db for local dev. DO NOT use PostgreSQL here;
# the ORM (drizzle + libsql) is configured for SQLite.
DATABASE_URL=file:sqlite.db

# Server port (defaults to 5000)
PORT=5000

# ─────────────────────────────────────────────────
# Groq API Key — OPTIONAL but HIGHLY RECOMMENDED
# Without this, AI features fall back to rule-based
# heuristics (still functional, just less intelligent).
# Get your key at: https://console.groq.com/keys
GROQ_API_KEY=gsk_...your-key-here...

# GitHub Personal Access Token — OPTIONAL
# Increases GitHub API rate limit from 60 to 5000 req/hour.
# Generate at: https://github.com/settings/tokens (public_repo scope)
GITHUB_TOKEN=github_pat_...your-token-here...

# Node environment: development | production
NODE_ENV=development
